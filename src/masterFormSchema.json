{
  "formVersion": "2.0.0",
  "platform": "Apply Pilot",
  "targetMarket": "US Students (F-1, OPT, STEM OPT, CPT, Green Card, Citizens)",
  "sections": [
    {
      "sectionId": "S1",
      "sectionName": "Personal Information",
      "apiCall": 1,
      "isArray": false,
      "fields": [
        {
          "id": "S1_F1",
          "key": "firstName",
          "label": "First Name",
          "type": "text",
          "mandatory": true,
          "aiCanAssume": false,
          "aiExtractFromResume": true,
          "userMustFillIfNull": true,
          "notes": "Extract exactly. If not found, return null."
        },
        {
          "id": "S1_F2",
          "key": "middleName",
          "label": "Middle Name",
          "type": "text",
          "mandatory": false,
          "aiCanAssume": false,
          "aiExtractFromResume": true,
          "userMustFillIfNull": false,
          "notes": "Only if explicitly present in resume."
        },
        {
          "id": "S1_F3",
          "key": "lastName",
          "label": "Last Name",
          "type": "text",
          "mandatory": true,
          "aiCanAssume": false,
          "aiExtractFromResume": true,
          "userMustFillIfNull": true,
          "notes": "Extract exactly. If not found, return null."
        },
        {
          "id": "S1_F4",
          "key": "preferredName",
          "label": "Preferred / Nick Name",
          "type": "text",
          "mandatory": false,
          "aiCanAssume": false,
          "aiExtractFromResume": true,
          "userMustFillIfNull": false,
          "notes": "Only if explicitly stated."
        },
        {
          "id": "S1_F5",
          "key": "email",
          "label": "Email Address",
          "type": "email",
          "mandatory": true,
          "aiCanAssume": false,
          "aiExtractFromResume": true,
          "userMustFillIfNull": true,
          "notes": "Extract exactly. Never guess."
        },
        {
          "id": "S1_F6",
          "key": "phone",
          "label": "Phone Number",
          "type": "tel",
          "mandatory": true,
          "aiCanAssume": false,
          "aiExtractFromResume": true,
          "userMustFillIfNull": true,
          "notes": "Extract exactly. Never guess."
        },
        {
          "id": "S1_F7",
          "key": "city",
          "label": "Current City",
          "type": "text",
          "mandatory": true,
          "aiCanAssume": false,
          "aiExtractFromResume": true,
          "userMustFillIfNull": true,
          "notes": "Extract exactly from resume address."
        },
        {
          "id": "S1_F8",
          "key": "state",
          "label": "State",
          "type": "select",
          "mandatory": true,
          "aiCanAssume": false,
          "aiExtractFromResume": true,
          "userMustFillIfNull": true,
          "options": "US States list",
          "notes": "Extract exactly. Do not infer from university location."
        },
        {
          "id": "S1_F9",
          "key": "zipCode",
          "label": "ZIP Code",
          "type": "text",
          "mandatory": false,
          "aiCanAssume": false,
          "aiExtractFromResume": true,
          "userMustFillIfNull": false,
          "notes": "Only if explicitly in resume."
        },
        {
          "id": "S1_F10",
          "key": "country",
          "label": "Country",
          "type": "text",
          "mandatory": true,
          "aiCanAssume": true,
          "aiExtractFromResume": true,
          "userMustFillIfNull": true,
          "aiAssumptionLogic": "If university is in USA, assume USA."
        },
        {
          "id": "S1_F11",
          "key": "linkedInUrl",
          "label": "LinkedIn Profile URL",
          "type": "url",
          "mandatory": false,
          "aiCanAssume": false,
          "aiExtractFromResume": true,
          "userMustFillIfNull": false,
          "notes": "Only if URL is explicitly in resume."
        },
        {
          "id": "S1_F12",
          "key": "githubUrl",
          "label": "GitHub Profile URL",
          "type": "url",
          "mandatory": false,
          "aiCanAssume": false,
          "aiExtractFromResume": true,
          "userMustFillIfNull": false,
          "notes": "Only if URL is explicitly in resume."
        },
        {
          "id": "S1_F13",
          "key": "portfolioUrl",
          "label": "Portfolio / Website URL",
          "type": "url",
          "mandatory": false,
          "aiCanAssume": false,
          "aiExtractFromResume": true,
          "userMustFillIfNull": false,
          "notes": "Only if URL is explicitly in resume."
        },
        {
          "id": "S1_F14",
          "key": "pronouns",
          "label": "Pronouns",
          "type": "select",
          "mandatory": false,
          "aiCanAssume": false,
          "aiExtractFromResume": false,
          "userMustFillIfNull": false,
          "options": [
            "He/Him",
            "She/Her",
            "They/Them",
            "Prefer not to say"
          ]
        }
      ]
    },
    {
      "sectionId": "S2",
      "sectionName": "Education",
      "apiCall": 2,
      "isArray": true,
      "arrayKey": "education",
      "arrayBehavior": {
        "allowMultiple": true,
        "minEntries": 1,
        "description": "Extract ALL education entries found in the resume as separate objects. Each degree or university = one separate object in the array. Never merge two degrees into one entry. Return array even if only one entry found."
      },
      "fields": [
        {
          "id": "S2_F1",
          "key": "universityName",
          "label": "University / College Name",
          "type": "text",
          "mandatory": true,
          "aiCanAssume": false,
          "aiExtractFromResume": true,
          "userMustFillIfNull": true,
          "notes": "Extract exactly."
        },
        {
          "id": "S2_F2",
          "key": "degree",
          "label": "Degree",
          "type": "select",
          "mandatory": true,
          "aiCanAssume": false,
          "aiExtractFromResume": true,
          "userMustFillIfNull": true,
          "options": [
            "High School Diploma",
            "Associate",
            "Bachelor's",
            "Master's",
            "MBA",
            "PhD",
            "Certificate"
          ]
        },
        {
          "id": "S2_F3",
          "key": "major",
          "label": "Major / Field of Study",
          "type": "text",
          "mandatory": true,
          "aiCanAssume": false,
          "aiExtractFromResume": true,
          "userMustFillIfNull": true,
          "notes": "Extract exactly."
        },
        {
          "id": "S2_F5",
          "key": "gpa",
          "label": "GPA",
          "type": "number",
          "mandatory": false,
          "aiCanAssume": false,
          "aiExtractFromResume": true,
          "userMustFillIfNull": false,
          "notes": "Extract exactly. Never calculate or estimate."
        },
        {
          "id": "S2_F6",
          "key": "gpaScale",
          "label": "GPA Scale (e.g. 4.0)",
          "type": "text",
          "mandatory": false,
          "aiCanAssume": true,
          "aiExtractFromResume": true,
          "userMustFillIfNull": false,
          "aiAssumptionLogic": "Default to 4.0 scale if not stated."
        },
        {
          "id": "S2_F7",
          "key": "eduStartDate",
          "label": "Start Date",
          "type": "month",
          "mandatory": true,
          "aiCanAssume": false,
          "aiExtractFromResume": true,
          "userMustFillIfNull": true,
          "notes": "Format: YYYY-MM. Extract exactly."
        },
        {
          "id": "S2_F8",
          "key": "eduEndDate",
          "label": "Graduation Date (Actual/Expected)",
          "type": "month",
          "mandatory": true,
          "aiCanAssume": false,
          "aiExtractFromResume": true,
          "userMustFillIfNull": true,
          "notes": "Format: YYYY-MM. Extract exactly. Never assume."
        }
      ]
    },
    {
      "sectionId": "S3",
      "sectionName": "Work Experience",
      "apiCall": 3,
      "isArray": true,
      "arrayKey": "workExperience",
      "arrayBehavior": {
        "allowMultiple": true,
        "minEntries": 0,
        "description": "Extract ALL work experience entries found in the resume as separate objects. Each job, internship, co-op, or research role = one separate object. Sort most recent first. Never merge two roles into one. Return empty array [] if no experience found."
      },
      "fields": [
        {
          "id": "S3_F1",
          "key": "companyName",
          "label": "Company / Organization Name",
          "type": "text",
          "mandatory": true,
          "aiCanAssume": false,
          "aiExtractFromResume": true,
          "userMustFillIfNull": true,
          "notes": "Extract exactly."
        },
        {
          "id": "S3_F2",
          "key": "jobTitle",
          "label": "Job Title",
          "type": "text",
          "mandatory": true,
          "aiCanAssume": false,
          "aiExtractFromResume": true,
          "userMustFillIfNull": true,
          "notes": "Extract exactly."
        },
        {
          "id": "S3_F3",
          "key": "workStartDate",
          "label": "Start Date",
          "type": "month",
          "mandatory": true,
          "aiCanAssume": false,
          "aiExtractFromResume": true,
          "userMustFillIfNull": true,
          "notes": "Format: YYYY-MM. Extract exactly."
        },
        {
          "id": "S3_F4",
          "key": "workEndDate",
          "label": "End Date",
          "type": "month",
          "mandatory": false,
          "aiCanAssume": false,
          "aiExtractFromResume": true,
          "userMustFillIfNull": false,
          "notes": "Return null if this is a current or ongoing role."
        },
        {
          "id": "S3_F5",
          "key": "currentlyWorking",
          "label": "Currently Working Here?",
          "type": "boolean",
          "mandatory": true,
          "aiCanAssume": true,
          "aiExtractFromResume": true,
          "userMustFillIfNull": true,
          "aiAssumptionLogic": "If end date is absent or says 'Present', set currentlyWorking = true."
        },
        {
          "id": "S3_F6",
          "key": "employmentType",
          "label": "Employment Type",
          "type": "select",
          "mandatory": true,
          "aiCanAssume": true,
          "aiExtractFromResume": true,
          "userMustFillIfNull": true,
          "options": [
            "Full-time",
            "Part-time",
            "Internship",
            "Co-op",
            "Contract",
            "Freelance",
            "Research"
          ],
          "aiAssumptionLogic": "Infer from title: 'Intern' = Internship, 'Research Assistant' = Research, 'Co-op' = Co-op."
        },
        {
          "id": "S3_F7",
          "key": "responsibilities",
          "label": "Key Responsibilities",
          "type": "textarea",
          "mandatory": true,
          "aiCanAssume": true,
          "aiExtractFromResume": true,
          "userMustFillIfNull": true,
          "aiAssumptionLogic": "Extract bullet points from resume exactly. May expand slightly for clarity but never fabricate achievements."
        }
      ]
    },
    {
      "sectionId": "S4",
      "sectionName": "Projects",
      "apiCall": 4,
      "isArray": true,
      "arrayKey": "projects",
      "arrayBehavior": {
        "allowMultiple": true,
        "minEntries": 0,
        "description": "Extract ALL projects found in resume as separate objects. Return empty array [] if no projects found."
      },
      "fields": [
        {
          "id": "S4_F1",
          "key": "projectName",
          "label": "Project Name",
          "type": "text",
          "mandatory": false,
          "aiCanAssume": false,
          "aiExtractFromResume": true,
          "userMustFillIfNull": false
        },
        {
          "id": "S4_F2",
          "key": "projectDescription",
          "label": "Project Description",
          "type": "textarea",
          "mandatory": false,
          "aiCanAssume": true,
          "aiExtractFromResume": true,
          "userMustFillIfNull": false,
          "aiAssumptionLogic": "Expand resume bullet points into a clear 2-3 sentence description."
        },
        {
          "id": "S4_F3",
          "key": "technologiesUsed",
          "label": "Technologies / Tools Used",
          "type": "tags",
          "mandatory": false,
          "aiCanAssume": true,
          "aiExtractFromResume": true,
          "userMustFillIfNull": false,
          "aiAssumptionLogic": "Extract all tools, languages, and frameworks explicitly mentioned in the project."
        },
        {
          "id": "S4_F4",
          "key": "projectUrl",
          "label": "Project / GitHub URL",
          "type": "url",
          "mandatory": false,
          "aiCanAssume": false,
          "aiExtractFromResume": true,
          "userMustFillIfNull": false,
          "notes": "Only if URL is explicitly stated in resume."
        },
        {
          "id": "S4_F5",
          "key": "projectDate",
          "label": "Project Date / Duration",
          "type": "text",
          "mandatory": false,
          "aiCanAssume": false,
          "aiExtractFromResume": true,
          "userMustFillIfNull": false
        }
      ]
    },
    {
      "sectionId": "S5",
      "sectionName": "Skills & Certifications",
      "apiCall": 5,
      "isArray": false,
      "fields": [
        {
          "id": "S5_F1",
          "key": "technicalSkills",
          "label": "Technical Skills",
          "type": "tags",
          "mandatory": true,
          "aiCanAssume": true,
          "aiExtractFromResume": true,
          "userMustFillIfNull": true,
          "aiAssumptionLogic": "Extract all tools, languages, and frameworks from the resume — skills section, project sections, and work experience descriptions."
        },
        {
          "id": "S5_F2",
          "key": "softSkills",
          "label": "Soft Skills",
          "type": "tags",
          "mandatory": false,
          "aiCanAssume": true,
          "aiExtractFromResume": true,
          "userMustFillIfNull": false,
          "aiAssumptionLogic": "Infer from job/project descriptions. e.g. 'led a team of 5' = Leadership, 'presented to stakeholders' = Communication."
        },
        {
          "id": "S5_F3",
          "key": "languages",
          "label": "Languages Spoken",
          "type": "array",
          "mandatory": false,
          "aiCanAssume": false,
          "aiExtractFromResume": true,
          "userMustFillIfNull": false,
          "notes": "Each entry: { language, proficiency: Native | Fluent | Intermediate | Basic }. Only if explicitly listed."
        },
        {
          "id": "S5_F4",
          "key": "certifications",
          "label": "Certifications",
          "type": "array",
          "mandatory": false,
          "aiCanAssume": false,
          "aiExtractFromResume": true,
          "userMustFillIfNull": false,
          "notes": "Each entry: { name, issuer, date, expiryDate }. Only if explicitly listed in resume."
        },
        {
          "id": "S5_F5",
          "key": "hobbies",
          "label": "Hobbies & Interests",
          "type": "tags",
          "mandatory": false,
          "aiCanAssume": false,
          "aiExtractFromResume": true,
          "userMustFillIfNull": false,
          "notes": "Only if explicitly mentioned in resume. User can add more manually from their profile."
        }
      ]
    },
    {
      "sectionId": "S6",
      "sectionName": "US Work Authorization",
      "apiCall": "SKIP — Always ask user directly. AI must never fill or assume any field in this section.",
      "isArray": false,
      "important": "THIS ENTIRE SECTION IS ALWAYS SHOWN TO USER. AI MUST NOT FILL OR ASSUME ANY OF THESE FIELDS.",
      "fields": [
        {
          "id": "S6_F1",
          "key": "citizenshipStatus",
          "label": "Citizenship / Immigration Status",
          "type": "select",
          "mandatory": true,
          "aiCanAssume": false,
          "aiExtractFromResume": false,
          "userMustFillIfNull": true,
          "options": [
            "US Citizen",
            "US Permanent Resident (Green Card)",
            "F-1 Student Visa",
            "H1-B",
            "L-1",
            "O-1",
            "TN Visa",
            "Other"
          ]
        },
        {
          "id": "S6_F2",
          "key": "workAuthType",
          "label": "Current Work Authorization",
          "type": "select",
          "mandatory": true,
          "aiCanAssume": false,
          "aiExtractFromResume": false,
          "userMustFillIfNull": true,
          "options": [
            "No authorization needed (Citizen / GC)",
            "OPT",
            "STEM OPT",
            "CPT",
            "H1-B Sponsored",
            "Other EAD"
          ]
        },
        {
          "id": "S6_F3",
          "key": "optStartDate",
          "label": "OPT Start Date",
          "type": "date",
          "mandatory": false,
          "aiCanAssume": false,
          "aiExtractFromResume": false,
          "userMustFillIfNull": false,
          "showIf": "workAuthType === 'OPT' || workAuthType === 'STEM OPT'"
        },
        {
          "id": "S6_F4",
          "key": "optEndDate",
          "label": "OPT End Date",
          "type": "date",
          "mandatory": false,
          "aiCanAssume": false,
          "aiExtractFromResume": false,
          "userMustFillIfNull": false,
          "showIf": "workAuthType === 'OPT' || workAuthType === 'STEM OPT'"
        },
        {
          "id": "S6_F5",
          "key": "stemOptEligible",
          "label": "STEM OPT Eligible?",
          "type": "boolean",
          "mandatory": false,
          "aiCanAssume": false,
          "aiExtractFromResume": false,
          "userMustFillIfNull": false,
          "showIf": "citizenshipStatus === 'F-1 Student Visa'"
        },
        {
          "id": "S6_F6",
          "key": "needSponsorship",
          "label": "Will you now or in the future require visa sponsorship?",
          "type": "boolean",
          "mandatory": true,
          "aiCanAssume": false,
          "aiExtractFromResume": false,
          "userMustFillIfNull": true
        },
        {
          "id": "S6_F7",
          "key": "authorizedToWork",
          "label": "Authorized to work in the US without restriction?",
          "type": "boolean",
          "mandatory": true,
          "aiCanAssume": false,
          "aiExtractFromResume": false,
          "userMustFillIfNull": true
        }
      ]
    },
    {
      "sectionId": "S7",
      "sectionName": "Job Preferences",
      "apiCall": "SKIP — Always ask user directly.",
      "isArray": false,
      "fields": [
        {
          "id": "S7_F1",
          "key": "desiredJobTitles",
          "label": "Desired Job Titles",
          "type": "tags",
          "mandatory": true,
          "aiCanAssume": true,
          "aiExtractFromResume": true,
          "userMustFillIfNull": true,
          "aiAssumptionLogic": "Infer from most recent job title and skills on resume."
        },
        {
          "id": "S7_F2",
          "key": "targetIndustries",
          "label": "Target Industries",
          "type": "tags",
          "mandatory": false,
          "aiCanAssume": true,
          "aiExtractFromResume": true,
          "userMustFillIfNull": false,
          "aiAssumptionLogic": "Infer from education and work experience on resume."
        },
        {
          "id": "S7_F3",
          "key": "workType",
          "label": "Preferred Work Type",
          "type": "select",
          "mandatory": true,
          "aiCanAssume": false,
          "aiExtractFromResume": false,
          "userMustFillIfNull": true,
          "options": [
            "Remote",
            "Hybrid",
            "On-site",
            "Any"
          ]
        },
        {
          "id": "S7_F4",
          "key": "preferredLocations",
          "label": "Preferred Cities / States",
          "type": "tags",
          "mandatory": false,
          "aiCanAssume": false,
          "aiExtractFromResume": false,
          "userMustFillIfNull": false
        },
        {
          "id": "S7_F5",
          "key": "willingToRelocate",
          "label": "Willing to Relocate?",
          "type": "boolean",
          "mandatory": true,
          "aiCanAssume": false,
          "aiExtractFromResume": false,
          "userMustFillIfNull": true
        },
        {
          "id": "S7_F6",
          "key": "employmentTypePref",
          "label": "Employment Type Preference",
          "type": "multiselect",
          "mandatory": true,
          "aiCanAssume": false,
          "aiExtractFromResume": false,
          "userMustFillIfNull": true,
          "options": [
            "Full-time",
            "Part-time",
            "Internship",
            "Co-op",
            "Contract"
          ]
        }
      ]
    },
    {
      "sectionId": "S8",
      "sectionName": "References",
      "apiCall": "SKIP — Always ask user directly.",
      "isArray": true,
      "arrayKey": "references",
      "arrayBehavior": {
        "allowMultiple": true,
        "minEntries": 0,
        "description": "User adds references manually. AI never fills this section."
      },
      "fields": [
        {
          "id": "S8_F1",
          "key": "refName",
          "label": "Reference Full Name",
          "type": "text",
          "mandatory": false,
          "aiCanAssume": false,
          "aiExtractFromResume": false,
          "userMustFillIfNull": false
        },
        {
          "id": "S8_F2",
          "key": "refTitle",
          "label": "Reference Job Title",
          "type": "text",
          "mandatory": false,
          "aiCanAssume": false,
          "aiExtractFromResume": false,
          "userMustFillIfNull": false
        },
        {
          "id": "S8_F3",
          "key": "refCompany",
          "label": "Reference Company",
          "type": "text",
          "mandatory": false,
          "aiCanAssume": false,
          "aiExtractFromResume": false,
          "userMustFillIfNull": false
        },
        {
          "id": "S8_F4",
          "key": "refRelationship",
          "label": "Your Relationship",
          "type": "select",
          "mandatory": false,
          "aiCanAssume": false,
          "aiExtractFromResume": false,
          "userMustFillIfNull": false,
          "options": [
            "Professor",
            "Manager",
            "Colleague",
            "Mentor",
            "Other"
          ]
        },
        {
          "id": "S8_F5",
          "key": "refEmail",
          "label": "Reference Email",
          "type": "email",
          "mandatory": false,
          "aiCanAssume": false,
          "aiExtractFromResume": false,
          "userMustFillIfNull": false
        },
        {
          "id": "S8_F6",
          "key": "refPhone",
          "label": "Reference Phone",
          "type": "tel",
          "mandatory": false,
          "aiCanAssume": false,
          "aiExtractFromResume": false,
          "userMustFillIfNull": false
        }
      ]
    },
    {
      "sectionId": "S9",
      "sectionName": "Account Credentials — For Auto-Applying",
      "apiCall": "SKIP — Always ask user directly. NEVER send to AI. NEVER log.",
      "isArray": false,
      "important": "SENSITIVE CREDENTIALS. MUST BE ENCRYPTED AT REST WITH AES-256. NEVER SEND TO ANY AI MODEL. NEVER APPEAR IN LOGS.",
      "displayNote": "⭐ Recommended — We use these accounts to auto-apply to jobs on your behalf. Without them, we cannot submit applications automatically.",
      "fields": [
        {
          "id": "S9_F1",
          "key": "linkedInEmail",
          "label": "LinkedIn Email Address",
          "type": "email",
          "mandatory": false,
          "recommended": true,
          "aiCanAssume": false,
          "aiExtractFromResume": false,
          "userMustFillIfNull": false,
          "encryption": "AES-256 required",
          "recommendationMessage": "⭐ Recommended — LinkedIn is used by 80% of employers. Adding your login lets us apply via Easy Apply automatically."
        },
        {
          "id": "S9_F2",
          "key": "linkedInPassword",
          "label": "LinkedIn Password",
          "type": "password",
          "mandatory": false,
          "recommended": true,
          "aiCanAssume": false,
          "aiExtractFromResume": false,
          "userMustFillIfNull": false,
          "encryption": "AES-256 required",
          "recommendationMessage": "⭐ Recommended — Required to submit LinkedIn Easy Apply applications on your behalf."
        },
        {
          "id": "S9_F3",
          "key": "linkedInPhone",
          "label": "LinkedIn Registered Phone Number",
          "type": "tel",
          "mandatory": false,
